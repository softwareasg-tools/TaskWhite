<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <title>TaskWhite - Office Tasks</title>
  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <!-- Flatpickr -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <!-- Canvas Confetti -->
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/legacy_mobile.css" media="(max-width: 991px)">
  
  <!-- Dark Mode Init -->
  <script>
    const mql = window.matchMedia('(prefers-color-scheme: dark)');
    const savedTheme = localStorage.getItem('theme_override');
    
    function applyTheme(theme) {
      document.documentElement.setAttribute('data-bs-theme', theme);
    }

    if (savedTheme) {
      applyTheme(savedTheme);
    } else {
      applyTheme(mql.matches ? 'dark' : 'light');
    }
    
    mql.addEventListener('change', (e) => {
      if (!localStorage.getItem('theme_override')) {
        applyTheme(e.matches ? 'dark' : 'light');
      }
    });
    
    function toggleTheme(e) {
      if(e) e.stopPropagation();
      const html = document.documentElement;
      const isDark = html.getAttribute('data-bs-theme') === 'dark';
      const newTheme = isDark ? 'light' : 'dark';
      applyTheme(newTheme);
      localStorage.setItem('theme_override', newTheme);
      const switchEl = document.getElementById('themeSwitch');
      const switchMobileEl = document.getElementById('themeSwitchMobile');
      if(switchEl) switchEl.checked = !isDark;
      if(switchMobileEl) switchMobileEl.checked = !isDark;
    }

    function resetThemeToSystem() {
      localStorage.removeItem('theme_override');
      applyTheme(mql.matches ? 'dark' : 'light');
    }
  </script>
  <link rel="icon" href="/favicon.png" type="image/png">
</head>
<body>
  <% if (user) { %>
    <!-- Top Navigation -->
    <nav class="navbar navbar-expand-lg sticky-top" style="z-index: 1040;">
      <div class="container-fluid px-4 justify-content-center justify-content-lg-between">
        <a class="navbar-brand d-flex align-items-center text-decoration-none" href="/dashboard">
          <img src="/images/logo.svg" alt="TaskWhite Logo" style="height: 30px; width: 30px; object-fit: cover; border-radius: 6px;" class="me-2 shadow-sm">
          <div class="brand-text">Task<span class="white-part">White</span></div>
        </a>
        <button class="navbar-toggler d-none" type="button" data-bs-toggle="collapse" data-bs-target="#topNavBar">
          <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse justify-content-end" id="topNavBar">
          <ul class="nav nav-pills align-items-center gap-2">
            <li class="nav-item">
              <a class="nav-link <%= currentPath === '/dashboard' || currentPath.startsWith('/tasks') ? 'active' : '' %>" href="/dashboard">
                <i class="bi bi-grid-1x2"></i> Dashboard
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= currentPath === '/task-archives' ? 'active' : '' %>" href="/task-archives">
                <i class="bi bi-archive"></i> Task Archives
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= currentPath === '/recycle-bin' ? 'active' : '' %>" href="/recycle-bin">
                <i class="bi bi-trash"></i> Recycle Bin
              </a>
            </li>
            <li class="nav-item ms-lg-2 mt-2 mt-lg-0 d-none d-lg-block">
              <a class="btn btn-dark btn-sm px-3 d-flex align-items-center" href="/dashboard?action=new" style="height: 36px; margin-top: 2px;">
                <i class="bi bi-plus me-1" style="font-size: 1.2rem;"></i> New Task
              </a>
            </li>
            <li class="nav-item dropdown ms-3">
              <a class="nav-link dropdown-toggle" style="background:transparent;" href="#" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle"></i>
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/clients">Clients</a></li>
                <li><a class="dropdown-item" href="/team">Team</a></li>
                <li><a class="dropdown-item" href="/task-types">Tasks</a></li>
                <li><a class="dropdown-item" href="/templates">Global Templates</a></li>
                <li><a class="dropdown-item" href="/settings">Settings</a></li>
                  <li>
                    <div class="dropdown-item d-flex justify-content-between align-items-center w-100 gap-3" onclick="toggleTheme(event)" style="cursor: pointer;">
                      <span><i class="bi bi-moon-stars me-1"></i> Dark</span>
                      <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="themeSwitch" style="pointer-events: none;">
                      </div>
                    </div>
                  </li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>
    
    <!-- Page Content -->
    <div class="container-fluid p-4 px-md-5">
      <%- body %>
    </div>
  <% } else { %>
    <!-- Login/Signup Layout -->
    <%- body %>
  <% } %>

  <% if (user) { %>
    <div class="bottom-nav-spacer d-lg-none" style="height: 80px;"></div>
    <!-- Mobile Bottom Navigation -->
    <nav class="bottom-nav d-flex d-lg-none">
      <a href="/dashboard" class="bottom-nav-item <%= currentPath === '/dashboard' || currentPath.startsWith('/tasks') ? 'active' : '' %>">
        <i class="bi bi-grid-1x2"></i>
        <span>Dashboard</span>
      </a>
      <a href="/clients" class="bottom-nav-item <%= currentPath === '/clients' ? 'active' : '' %>">
        <i class="bi bi-people"></i>
        <span>Clients</span>
      </a>
      <div class="bottom-nav-fab-wrapper">
        <a href="/dashboard?action=new" class="fab-button shadow-lg">
          <i class="bi bi-plus-lg"></i>
        </a>
      </div>
      <a href="/task-archives" class="bottom-nav-item <%= currentPath === '/task-archives' ? 'active' : '' %>">
        <i class="bi bi-archive"></i>
        <span>Archives</span>
      </a>
      <a href="/recycle-bin" class="bottom-nav-item <%= currentPath === '/recycle-bin' ? 'active' : '' %>">
        <i class="bi bi-trash"></i>
        <span>Trash</span>
      </a>
      <div class="bottom-nav-item dropup">
        <a href="#" class="text-decoration-none d-flex flex-column align-items-center dropdown-toggle-bottom" data-bs-toggle="dropdown" style="color: inherit;">
          <i class="bi bi-person-circle"></i>
          <span>More</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end dropdown-menu-bottom shadow" style="margin-bottom: 0.5rem;">
          <li><a class="dropdown-item" href="/team">Team</a></li>
          <li><a class="dropdown-item" href="/task-types">Tasks</a></li>
          <li><a class="dropdown-item" href="/templates">Global Templates</a></li>
          <li><a class="dropdown-item" href="/settings">Settings</a></li>
          <li>
            <div class="dropdown-item d-flex justify-content-between align-items-center w-100 gap-3" onclick="toggleTheme(event)" style="cursor: pointer;">
              <span><i class="bi bi-moon-stars me-1"></i> Dark</span>
              <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" id="themeSwitchMobile" style="pointer-events: none;">
              </div>
            </div>
          </li>
          <li><hr class="dropdown-divider"></li>
          <li><a class="dropdown-item" href="/logout">Logout</a></li>
        </ul>
      </div>
    </nav>
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Sync the switches on load
    document.addEventListener('DOMContentLoaded', () => {
      const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
      const themeSwitch = document.getElementById('themeSwitch');
      const themeSwitchMobile = document.getElementById('themeSwitchMobile');
      if (themeSwitch) themeSwitch.checked = isDark;
      if (themeSwitchMobile) themeSwitchMobile.checked = isDark;
      
      // Global Modal Autofocus Logic
      const modals = document.querySelectorAll('.modal');
      modals.forEach(modal => {
        modal.addEventListener('shown.bs.modal', function () {
          // Focus the primary action button (btn-primary, btn-danger, or btn-dark)
          // Focus based on data-autofocus attribute, then fallback to first input, then fallback to primary btn
          const explicitFocus = modal.querySelector('[data-autofocus="true"]');
          const firstInput = modal.querySelector('input:not([type="hidden"]), select, textarea');
          if (explicitFocus) {
             explicitFocus.focus();
          } else if (firstInput) {
            firstInput.focus();
          } else {
            const primaryBtn = modal.querySelector('.modal-footer .btn-primary, .modal-footer .btn-danger, .modal-footer .btn-dark, .modal-footer button[type="submit"]');
            if (primaryBtn) primaryBtn.focus();
          }
        });
      });

      // Check for flash messages
      const flashMessage = sessionStorage.getItem('flashMessage');
      if (flashMessage) {
        showToast(flashMessage, 'success');
        sessionStorage.removeItem('flashMessage');
      }
    });

    // Global helper to reload with a success message
    function reloadWithSuccess(message = 'Action completed successfully!', taskId = null) {
      sessionStorage.setItem('flashMessage', message);
      if (taskId) sessionStorage.setItem('highlightTask', taskId);
      window.location.reload();
    }

    // Bulk Action Logic
    function toggleAllCheckboxes(event) {
      const isChecked = event.target.checked;
      const rowCheckboxes = document.querySelectorAll('.row-checkbox');
      rowCheckboxes.forEach(cb => cb.checked = isChecked);
      updateBulkDeleteAction();
    }

    function updateBulkDeleteAction() {
      const checkedCount = document.querySelectorAll('.row-checkbox:checked').length;
      const actionBar = document.getElementById('bulkActionBar');
      const countLabel = document.getElementById('bulkSelectedCount');
      if (actionBar) {
        if (checkedCount > 0) {
          actionBar.style.display = 'flex';
          if(countLabel) countLabel.innerText = checkedCount + ' selected';
        } else {
          actionBar.style.display = 'none';
        }
      }
      
      const masterCheck = document.querySelector('.master-checkbox');
      const allRowChecks = document.querySelectorAll('.row-checkbox');
      if (masterCheck && allRowChecks.length > 0) {
        masterCheck.checked = checkedCount === allRowChecks.length;
      }
    }

    // Global Toast Notification System
    function showToast(message, type = 'success') {
      const container = document.getElementById('globalToastContainer');
      const bgClass = type === 'success' ? 'bg-success' : 'bg-danger';
      const toastHtml = `
        <div class="toast align-items-center text-white ${bgClass} border-0 show" role="alert" aria-live="assertive" aria-atomic="true" style="opacity:0; transition: opacity 0.3s; margin-top: 10px;">
          <div class="d-flex">
            <div class="toast-body fw-bold">
              ${message}
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close" onclick="this.closest('.toast').remove()"></button>
          </div>
        </div>
      `;
      container.insertAdjacentHTML('beforeend', toastHtml);
      const toastEl = container.lastElementChild;
      
      // Fade in
      setTimeout(() => toastEl.style.opacity = '1', 10);
      
      // Auto remove
      setTimeout(() => {
        toastEl.style.opacity = '0';
        setTimeout(() => toastEl.remove(), 300);
      }, 10000);
    }
  </script>

  <!-- Global Toast Container -->
  <div id="globalToastContainer" class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;"></div>
</body>
</html>
