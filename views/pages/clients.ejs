<div style="position: sticky; top: 60px; z-index: 1020; background-color: var(--bg-color); padding: 15px 0 10px 0; margin-top: -15px; margin-bottom: 15px;">
<div class="d-flex justify-content-between align-items-center">
  <div>
    <div class="section-subtitle">MASTER DATA</div>
    <h1 class="page-title mb-0">Clients</h1>
  </div>
  <div class="d-flex gap-3">
    <div class="input-group">
      <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
      <input type="text" id="clientSearch" class="form-control border-start-0 ps-0" placeholder="Search clients...">
    </div>
    <button class="btn btn-dark text-nowrap" data-bs-toggle="modal" data-bs-target="#addClientModal"><i class="bi bi-plus"></i> Add Client</button>
  </div>
</div>

<div id="bulkActionBar" class="bulk-action-bar mt-3" style="margin-bottom: 0;">
  <div class="fw-bold"><span id="bulkSelectedCount">0 selected</span></div>
  <button class="btn btn-danger btn-sm" onclick="confirmBulkDeleteClients()">
    <i class="bi bi-trash"></i> Delete Selected
  </button>
</div>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="bg-light">
          <tr>
            <th style="width: 40px;"><input type="checkbox" class="form-check-input master-checkbox" onchange="toggleAllCheckboxes(event)"></th>
            <th onclick="sortTable(1)" style="cursor: pointer;">Name <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(2)" style="cursor: pointer;">Notes <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (clients.length === 0) { %>
            <tr><td colspan="4" class="text-center text-muted p-4">No clients found.</td></tr>
          <% } %>
          <% clients.forEach(client => { %>
            <tr class="client-row">
              <td><input type="checkbox" class="form-check-input row-checkbox" value="<%= client.id %>" onchange="updateBulkDeleteAction()"></td>
              <td class="fw-bold client-name"><%= client.name %></td>
              <td><%= client.notes || '-' %></td>
              <td class="text-end">
                <button class="btn btn-link text-decoration-none text-danger p-0" onclick="confirmDeleteClient('<%= client.id %>', '<%= client.name.replace(/'/g, "\\'") %>')">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Client Modal -->
<div class="modal fade" id="addClientModal" tabindex="-1" aria-labelledby="addClientModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <form class="modal-content" onsubmit="event.preventDefault(); submitAddClient();">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="addClientModalLabel">Add Client</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="addClientError" class="alert alert-danger small py-2" style="display: none;"></div>
        
        <div class="form-check form-switch mb-3">
          <input class="form-check-input" type="checkbox" id="bulkAddToggle" onchange="toggleBulkAdd()">
          <label class="form-check-label text-muted small fw-bold" for="bulkAddToggle">BULK ADD MODE</label>
        </div>

        <div id="singleAddMode">
          <div class="mb-3">
            <label for="clientName" class="form-label text-muted small fw-bold">CLIENT NAME <span class="text-danger">*</span></label>
            <input type="text" id="clientName" class="form-control" placeholder="e.g. Reliance Industries">
          </div>
          <div class="mb-3">
            <label for="clientNotes" class="form-label text-muted small fw-bold">NOTES</label>
            <textarea id="clientNotes" class="form-control" rows="3" placeholder="Add any specific details..."></textarea>
          </div>
        </div>

        <div id="bulkAddMode" style="display: none;">
          <div class="mb-3">
            <label for="bulkClientNames" class="form-label text-muted small fw-bold">CLIENT NAMES (ONE PER LINE) <span class="text-danger">*</span></label>
            <textarea id="bulkClientNames" class="form-control" rows="6" placeholder="Reliance Industries&#10;Tata Consultancy Services&#10;HDFC Bank"></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer border-top-0 pt-0">
        <button type="button" class="btn btn-link text-decoration-none text-dark fw-medium" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-dark">Add Client(s)</button>
      </div>
    </form>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteClientModal" tabindex="-1" aria-labelledby="deleteClientModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 450px;">
    <div class="modal-content">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="deleteClientModalLabel">Delete Client?</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body py-3">
        <div id="deleteClientDetails" class="fw-bold mb-2" style="color: #111;"></div>
        <p class="text-muted small mb-0">Are you sure you want to delete this client? This will permanently affect tasks assigned to them.</p>
      </div>
      <div class="modal-footer border-top-0 pt-0 justify-content-end gap-2">
        <button type="button" class="btn btn-link text-decoration-none text-dark fw-medium" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger px-3 py-2 fw-medium text-white" style="border-radius: 8px;" onclick="executeDeleteClient()">Delete Client</button>
      </div>
    </div>
  </div>
</div>

<script>
  let activeDeleteClientId = null;
  let deleteClientModalObj = null;
  let addClientModalObj = null;

  function confirmDeleteClient(clientId, clientName) {
    activeDeleteClientId = clientId;
    document.getElementById('deleteClientDetails').innerText = clientName;
    if (!deleteClientModalObj) {
      deleteClientModalObj = new bootstrap.Modal(document.getElementById('deleteClientModal'));
    }
    deleteClientModalObj.show();
  }

  async function executeDeleteClient() {
    try {
      const ids = Array.isArray(activeDeleteClientId) ? activeDeleteClientId : [activeDeleteClientId];
      for (const id of ids) {
        const response = await fetch(`/clients/${id}`, { method: 'DELETE' });
        if (!response.ok) {
          const data = await response.json();
          throw new Error(data.error || 'Failed to delete client');
        }
      }
      deleteClientModalObj.hide();
      reloadWithSuccess('Action completed successfully!');
    } catch (err) {
      console.error(err);
      showToast(err.message, 'danger');
    }
  }

  function confirmBulkDeleteClients() {
    const checked = document.querySelectorAll('.row-checkbox:checked');
    if (checked.length === 0) return;
    const ids = Array.from(checked).map(cb => cb.value);
    activeDeleteClientId = ids;
    document.getElementById('deleteClientDetails').innerText = `${ids.length} client(s) selected`;
    if (!deleteClientModalObj) {
      deleteClientModalObj = new bootstrap.Modal(document.getElementById('deleteClientModal'));
    }
    deleteClientModalObj.show();
  }

  function toggleBulkAdd() {
    const isBulk = document.getElementById('bulkAddToggle').checked;
    document.getElementById('singleAddMode').style.display = isBulk ? 'none' : 'block';
    document.getElementById('bulkAddMode').style.display = isBulk ? 'block' : 'none';
  }

  async function submitAddClient() {
    const errorDiv = document.getElementById('addClientError');
    const isBulk = document.getElementById('bulkAddToggle').checked;
    
    errorDiv.style.display = 'none';
    
    let payload = {};
    let url = '';

    if (isBulk) {
      const bulkInput = document.getElementById('bulkClientNames').value;
      const names = bulkInput.split('\\n').map(n => n.trim()).filter(n => n);
      if (names.length === 0) {
        errorDiv.innerText = 'Please enter at least one client name.';
        errorDiv.style.display = 'block';
        return;
      }
      payload = { names };
      url = '/api/clients/bulk';
    } else {
      const name = document.getElementById('clientName').value.trim();
      const notes = document.getElementById('clientNotes').value.trim();
      if (!name) {
        errorDiv.innerText = 'Client name is required.';
        errorDiv.style.display = 'block';
        return;
      }
      payload = { name, notes };
      url = '/api/clients';
    }
    
    try {
      const response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      
      const data = await response.json();
      if (response.ok) {
        if (!addClientModalObj) {
          addClientModalObj = bootstrap.Modal.getInstance(document.getElementById('addClientModal'));
        }
        addClientModalObj?.hide();
        reloadWithSuccess('Action completed successfully!');
      } else {
        errorDiv.innerText = data.error || 'Failed to add client(s).';
        errorDiv.style.display = 'block';
      }
    } catch (err) {
      console.error(err);
      errorDiv.innerText = 'Server error. Please try again.';
      errorDiv.style.display = 'block';
    }
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    addClientModalObj = new bootstrap.Modal(document.getElementById('addClientModal'));
    
    // Reactive Search
    const searchInput = document.getElementById('clientSearch');
    const rows = document.querySelectorAll('.client-row');
    
    if (searchInput) {
      searchInput.addEventListener('keyup', (e) => {
        const term = e.target.value.toLowerCase();
        rows.forEach(row => {
          const name = row.querySelector('.client-name').textContent.toLowerCase();
          if (name.includes(term)) {
            row.style.display = '';
          } else {
            row.style.display = 'none';
          }
        });
      });
    }

    // Enter key support for modal inputs
    const clientNameInput = document.getElementById('clientName');
    const clientNotesInput = document.getElementById('clientNotes');
    
    function handleEnter(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        submitAddClient();
      }
    }

    if (clientNameInput) clientNameInput.addEventListener('keypress', handleEnter);
    // Don't bind enter on clientNotes because it's a textarea and we might want newlines
  });

  let currentSortCol = -1;
  let currentSortDir = 'asc';
  
  function sortTable(n) {
    const table = document.querySelector(".table");
    const tbody = table.querySelector("tbody");
    const rows = Array.from(tbody.querySelectorAll("tr"));
    
    // Ignore if empty state
    if (rows.length === 0 || rows[0].querySelector("td[colspan]")) return;

    if (currentSortCol === n) {
      currentSortDir = currentSortDir === 'asc' ? 'desc' : 'asc';
    } else {
      currentSortCol = n;
      currentSortDir = 'asc';
    }

    rows.sort((a, b) => {
      const aText = a.cells[n].innerText.toLowerCase();
      const bText = b.cells[n].innerText.toLowerCase();
      
      if (aText < bText) return currentSortDir === 'asc' ? -1 : 1;
      if (aText > bText) return currentSortDir === 'asc' ? 1 : -1;
      return 0;
    });

    tbody.append(...rows);
  }
</script>
