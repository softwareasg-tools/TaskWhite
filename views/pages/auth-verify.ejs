<div class="container d-flex justify-content-center align-items-center vh-100">
  <div class="card shadow-sm" style="width: 100%; max-width: 400px; border-radius: 10px; margin: 0 15px;">
    <div class="card-body p-4 text-center">
      <a href="/" class="text-decoration-none text-reset d-block">
        <img src="/images/logo.svg" alt="TaskWhite Logo" style="height: 64px; width: 64px; object-fit: cover; border-radius: 14px;" class="mb-3 shadow-sm">
        <div class="d-flex justify-content-center mb-4">
          <h3 class="card-title text-center mb-0 brand-text" style="font-size: 2.25rem; color: inherit;">Task<span class="white-part">White</span></h3>
        </div>
      </a>
      
      <div id="status" class="alert alert-info py-2">
        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
        Verifying your magic link...
      </div>

      <!-- Sleek Email Confirmation Block -->
      <div id="emailConfirmBlock" style="display: none; text-align: left;">
        <p class="text-muted mb-3 text-center" style="font-size: 14px;">For security, please confirm your email address to complete sign in.</p>
        <div class="mb-3">
          <input type="email" id="confirmEmail" class="form-control text-center" placeholder="name@company.com">
        </div>
        <button id="confirmEmailBtn" class="btn btn-dark w-100">Confirm Email</button>
      </div>
      
      <div class="alert alert-danger py-2 mt-3" id="errorDiv" style="display: none;"></div>
      
      <a href="/login" class="btn btn-outline-secondary w-100 mt-3" id="retryBtn" style="display: none;">Return to Login</a>
    </div>
  </div>
</div>

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
  import { getAuth, isSignInWithEmailLink, signInWithEmailLink } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js";

  const firebaseConfig = <%- firebaseConfig || '{}' %>;
  const app = initializeApp(firebaseConfig);
  const auth = getAuth(app);
  
  const statusDiv = document.getElementById('status');
  const errorDiv = document.getElementById('errorDiv');
  const retryBtn = document.getElementById('retryBtn');
  const emailConfirmBlock = document.getElementById('emailConfirmBlock');
  const confirmEmailInput = document.getElementById('confirmEmail');
  const confirmEmailBtn = document.getElementById('confirmEmailBtn');

  const originalUrl = window.location.href;

  async function processLogin(emailToUse) {
    try {
      statusDiv.style.display = 'block';
      emailConfirmBlock.style.display = 'none';
      errorDiv.style.display = 'none';
      retryBtn.style.display = 'none';

      const result = await signInWithEmailLink(auth, emailToUse, originalUrl);
      window.localStorage.removeItem('emailForSignIn');
      const user = result.user;
      
      statusDiv.innerHTML = '<div class="spinner-border spinner-border-sm me-2" role="status"></div> Finalizing workspace...';
      
      const res = await fetch('/api/auth/post-login-routing', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: user.email, name: user.displayName || '', firebaseUserId: user.uid })
      });
      const data = await res.json();
      
      if (res.ok) {
        window.history.replaceState({}, document.title, '/auth/verify');
        window.location.href = '/dashboard';
      } else {
        throw new Error(data.error || 'Failed to setup workspace routing.');
      }
    } catch (err) {
      console.error(err);
      statusDiv.style.display = 'none';
      
      let friendlyMsg = 'Verification failed. The link may be expired or invalid. Please request a new one.';
      if (err.code === 'auth/invalid-email') {
        friendlyMsg = 'The email you entered is incorrect. Please re-enter the exact email address you used to request this link.';
        emailConfirmBlock.style.display = 'block';
      } else if (err.code === 'auth/invalid-action-code') {
        friendlyMsg = 'This magic link has expired or has already been used. Please return to the login page to request a new one.';
        retryBtn.style.display = 'block';
        window.history.replaceState({}, document.title, '/auth/verify'); // wipe URL on permanent error
      } else {
        if (err.message) friendlyMsg = err.message.replace('Firebase:', '').trim();
        retryBtn.style.display = 'block';
      }
      
      errorDiv.innerText = friendlyMsg;
      errorDiv.style.display = 'block';
    }
  }

  function init() {
    if (!isSignInWithEmailLink(auth, originalUrl)) {
      statusDiv.style.display = 'none';
      errorDiv.innerText = 'Invalid magic link URL.';
      errorDiv.style.display = 'block';
      retryBtn.style.display = 'block';
      return;
    }
    
    let storedEmail = window.localStorage.getItem('emailForSignIn');
    if (storedEmail) {
      processLogin(storedEmail);
    } else {
      statusDiv.style.display = 'none';
      emailConfirmBlock.style.display = 'block';
    }
  }

  const submitEmail = () => {
    const inputVal = confirmEmailInput.value.trim();
    if (inputVal) {
      processLogin(inputVal);
    } else {
      errorDiv.innerText = 'Please enter an email address.';
      errorDiv.style.display = 'block';
    }
  };

  confirmEmailBtn.addEventListener('click', submitEmail);
  confirmEmailInput.addEventListener('keyup', (event) => {
    if (event.key === 'Enter') submitEmail();
  });

  init();
</script>
