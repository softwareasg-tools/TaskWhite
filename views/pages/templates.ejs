<div style="position: sticky; top: 60px; z-index: 1020; background-color: var(--bg-color); padding: 15px 0 10px 0; margin-top: -15px; margin-bottom: 15px;">
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
  <div>
    <div class="section-subtitle">COMPLIANCE</div>
    <h1 class="page-title mb-0">Global Templates</h1>
  </div>
  <div class="d-flex flex-wrap gap-2 gap-sm-3 align-items-center">
    <div class="input-group">
      <span class="input-group-text bg-surface border-end-0"><i class="bi bi-search text-muted"></i></span>
      <input type="text" id="templateSearch" class="form-control border-start-0 ps-0" placeholder="Search templates...">
    </div>
    <button class="btn btn-dark text-nowrap" data-bs-toggle="modal" data-bs-target="#addTemplateModal"><i class="bi bi-plus"></i> Add Template</button>
  </div>
</div>
</div>

<div class="card border-0 bg-transparent bg-md-surface border-md shadow-sm-md">
  <div class="card-body p-0 bg-transparent bg-md-surface">
    <!-- Desktop Table View -->
    <div class="table-responsive d-none d-md-block">
      <table class="table table-hover mb-0">
        <thead class="bg-surface">
          <tr>
            <th>Task Name</th>
            <th>Frequency</th>
            <th>Default Assignee</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody id="templateTableBody">
          <% if (templates.length === 0) { %>
            <tr><td colspan="4" class="text-center text-muted p-4">No global templates configured. Spawning compliance tasks across all clients automatically.</td></tr>
          <% } %>
          <% templates.forEach(temp => { %>
            <tr class="template-row">
              <td>
                <i class="bi bi-file-earmark-check text-primary me-2"></i>
                <span class="fw-bold"><%= temp.TaskType ? temp.TaskType.name : 'Unknown' %></span>
              </td>
              <td>
                <% if (temp.recurrence_rule && temp.recurrence_rule.frequency === 'monthly') { %>
                  <span class="badge bg-surface  border">Monthly (on day <%= temp.recurrence_rule.monthlyDay || 20 %>)</span>
                <% } else { %>
                  <span class="badge bg-surface  border">Recurring</span>
                <% } %>
              </td>
              <td>
                <%= temp.Assignee ? temp.Assignee.name : '-' %>
              </td>
              <td class="text-end">
                <button class="btn btn-link text-decoration-none text-danger p-0" onclick="confirmDeleteTemplate('<%= temp.id %>', '<%= temp.TaskType ? temp.TaskType.name.replace(/\x27/g, `\\\'`) : `Unknown` %>')">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Mobile Tile List View -->
    <div class="d-block d-md-none">
      <% if (templates.length === 0) { %>
        <div class="text-center text-muted p-4 bg-surface rounded border">No global templates configured.</div>
      <% } %>
      <div class="d-flex flex-column gap-3">
        <% templates.forEach(temp => { %>
          <div class="p-3 border rounded shadow-sm bg-surface">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <div>
                <h6 class="fw-bold mb-1 ">
                  <i class="bi bi-file-earmark-check text-primary me-1"></i>
                  <%= temp.TaskType ? temp.TaskType.name : 'Unknown' %>
                </h6>
                <div class="text-muted small" style="font-size: 0.75rem;">Assignee: <%= temp.Assignee ? temp.Assignee.name : '-' %></div>
              </div>
              <div class="d-flex flex-column align-items-end gap-1">
                <% if (temp.recurrence_rule && temp.recurrence_rule.frequency === 'monthly') { %>
                  <span class="badge bg-surface  border" style="font-size: 0.65rem;">Monthly (day <%= temp.recurrence_rule.monthlyDay || 20 %>)</span>
                <% } else { %>
                  <span class="badge bg-surface  border" style="font-size: 0.65rem;">Recurring</span>
                <% } %>
              </div>
            </div>
            <div class="d-flex justify-content-end border-top pt-2">
              <button class="btn btn-sm btn-outline-danger py-1 px-2" style="font-size: 0.7rem;" onclick="confirmDeleteTemplate('<%= temp.id %>', '<%= temp.TaskType ? temp.TaskType.name.replace(/\x27/g, `\\\'`) : `Unknown` %>')">
                <i class="bi bi-trash"></i> Delete
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>

<!-- Add Template Modal -->
<div class="modal fade" id="addTemplateModal" tabindex="-1" aria-labelledby="addTemplateModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 450px;">
    <form class="modal-content" onsubmit="event.preventDefault(); submitAddTemplate();">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="addTemplateModalLabel">Add Global Template</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="addTemplateError" class="alert alert-danger small py-2" style="display: none;"></div>
        
        <div class="mb-3">
          <label for="templateTaskType" class="form-label text-muted small fw-bold">TASK <span class="text-danger">*</span></label>
          <div class="dropdown">
            <button class="form-select text-start d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false" id="templateTaskTypeBtn">
              <span class="text-muted">Select Task...</span>
            </button>
            <ul class="dropdown-menu w-100 shadow-sm border-0 py-2" style="max-height: 300px; overflow-y: auto;">
              <li>
                <a class="dropdown-item fw-bold text-primary py-2 d-flex align-items-center gap-2" style="background-color: var(--bg-subtle);" href="#" onclick="handleInlineCreateCustom('task_type', event)">
                  <i class="bi bi-plus-circle-fill"></i> Add New Task
                </a>
              </li>
              <li><hr class="dropdown-divider"></li>
              <% taskTypes.forEach(type => { %>
                <li><a class="dropdown-item py-2" href="#" onclick="selectDropdownOption('task_type', '<%= type.id %>', '<%= type.name.replace(/\x27/g, '\\\'') %>', event)"><%= type.name %></a></li>
              <% }) %>
            </ul>
            <input type="hidden" id="templateTaskType" required>
          </div>
        </div>

        <div class="mb-3">
          <label for="templateAssignee" class="form-label text-muted small fw-bold">DEFAULT ASSIGNEE</label>
          <select id="templateAssignee" class="form-select">
            <option value="">Unassigned</option>
            <% users.forEach(user => { %>
              <option value="<%= user.id %>"><%= user.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="mb-3">
          <label class="form-label text-muted small fw-bold">RECURRENCE</label>
          <div class="p-3 bg-surface rounded border">
            <div class="row g-2">
              <div class="col-6">
                <label class="form-label text-muted small" style="font-size: 0.7rem;">FREQUENCY</label>
                <select id="template_freq" class="form-select form-select-sm" disabled>
                  <option value="monthly">Monthly</option>
                </select>
              </div>
              <div class="col-6">
                <label class="form-label text-muted small" style="font-size: 0.7rem;">DAY OF MONTH</label>
                <input type="number" id="template_day" class="form-control form-control-sm" min="1" max="31" value="20" required>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer border-top-0 pt-0">
        <button type="button" class="btn btn-link text-decoration-none  fw-medium" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-dark">Add Template</button>
      </div>
    </form>
  </div>
</div>

<script>
  // Search Templates
  document.getElementById('templateSearch').addEventListener('keyup', function(e) {
    const term = e.target.value.toLowerCase();
    const rows = document.querySelectorAll('.template-row');
    rows.forEach(row => {
      if (row.innerText.toLowerCase().includes(term)) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  });

  async function submitAddTemplate() {
    const errorDiv = document.getElementById('addTemplateError');
    errorDiv.style.display = 'none';

    const payload = {
      task_type_id: document.getElementById('templateTaskType').value,
      assigned_user_id: document.getElementById('templateAssignee').value,
      recurrence_rule: {
        frequency: 'monthly',
        interval: 1,
        monthlyType: 'dayOfMonth',
        monthlyDay: parseInt(document.getElementById('template_day').value || 20, 10),
        endType: 'never'
      }
    };

    try {
      const response = await fetch('/api/templates', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await response.json();
      if (response.ok) {
        reloadWithSuccess('Global template saved and tasks generated successfully!');
      } else {
        errorDiv.innerText = data.error || 'Failed to add template.';
        errorDiv.style.display = 'block';
      }
    } catch (err) {
      console.error(err);
      errorDiv.innerText = 'Server error. Please try again.';
      errorDiv.style.display = 'block';
    }
  }

  async function confirmDeleteTemplate(id, name) {
    if (!confirm(`Are you sure you want to delete the global template for "${name}"?\nNote: This will also remove any incomplete dashboard tasks generated by this template.`)) return;
    try {
      const response = await fetch(`/templates/${id}`, { method: 'DELETE' });
      if (response.ok) {
        reloadWithSuccess('Global template deleted successfully!');
      } else {
        showToast('Failed to delete template.', 'danger');
      }
    } catch (err) {
      console.error(err);
      showToast('Error deleting template.', 'danger');
    }
  }


  function selectDropdownOption(type, id, name, e) {
    if(e) e.preventDefault();
    if(type === 'task_type') {
      const btn = document.getElementById('templateTaskTypeBtn');
      if (btn) btn.innerHTML = '<span>' + name + '</span>';
      const hidden = document.getElementById('templateTaskType');
      if (hidden) hidden.value = id;
    }
  }

  async function handleInlineCreateCustom(type, event) {
    if (event) event.preventDefault();
    let name = prompt('Enter new Task name:');
    if (!name || name.trim() === '') return;
    try {
      const res = await fetch('/api/task-types', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name.trim() })
      });
      const data = await res.json();
      if (res.ok) {
        selectDropdownOption('task_type', data.taskType.id, data.taskType.name);
        showToast('Task added successfully', 'success');
        setTimeout(() => location.reload(), 1000); // Reload to show in list
      } else {
        showToast(data.error || 'Failed to create task', 'danger');
      }
    } catch (err) {
      console.error(err);
      showToast('Server error', 'danger');
    }
  }
</script>
