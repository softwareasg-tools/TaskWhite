<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <div class="section-subtitle">MASTER DATA</div>
    <h1 class="page-title mb-0">Team Members</h1>
  </div>
  <div class="d-flex gap-3">
    <div class="input-group">
      <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
      <input type="text" id="teamSearch" class="form-control border-start-0 ps-0" placeholder="Search team...">
    </div>
    <button class="btn btn-dark text-nowrap" data-bs-toggle="modal" data-bs-target="#addTeamModal"><i class="bi bi-plus"></i> Add Member</button>
  </div>
</div>

<div id="bulkActionBar" class="bulk-action-bar" style="display: none; padding: 10px; background: #f8f9fa; border: 1px solid #dee2e6; margin-bottom: 1rem; border-radius: 4px; display: flex; align-items: center; justify-content: space-between;">
  <div class="fw-bold"><span id="bulkSelectedCount">0 selected</span></div>
  <button class="btn btn-danger btn-sm" onclick="confirmBulkDeleteUsers()">
    <i class="bi bi-trash"></i> Delete Selected
  </button>
</div>

<div class="alert alert-info mb-4" role="alert">
  <i class="bi bi-info-circle-fill me-2"></i>
  <strong>Role Definitions:</strong><br>
  <ul class="mb-0 mt-1">
    <li><strong>Owner:</strong> Full access, including billing/settings and permanent deletion of tasks from the recycle bin.</li>
    <li><strong>Admin:</strong> Can manage users, clients, and task types, but cannot delete tasks permanently.</li>
    <li><strong>Member:</strong> Standard access; can view clients, create tasks, and manage assigned tasks.</li>
  </ul>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="bg-light">
          <tr>
            <th style="width: 40px;"><input type="checkbox" class="form-check-input master-checkbox" onchange="toggleAllCheckboxes(event)"></th>
            <th onclick="sortTable(1)" style="cursor: pointer;">Name <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(2)" style="cursor: pointer;">Email <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(3)" style="cursor: pointer;">Role <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(4)" style="cursor: pointer;">Status <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (team.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted p-4">No team members found.</td></tr>
          <% } %>
          <% team.forEach(member => { %>
            <tr class="team-row">
              <td><input type="checkbox" class="form-check-input row-checkbox" value="<%= member.id %>" onchange="updateBulkDeleteAction()"></td>
              <td>
                <i class="bi bi-person-circle text-muted me-2"></i>
                <span class="fw-bold team-name"><%= member.name %></span>
              </td>
              <td><%= member.email %></td>
              <td><span class="badge badge-outline"><%= member.role %></span></td>
              <td>
                <% if (member.status === 'Active') { %>
                  <span class="text-success"><i class="bi bi-check-circle-fill"></i> Active</span>
                <% } else { %>
                  <span class="text-muted"><i class="bi bi-x-circle-fill"></i> Inactive</span>
                <% } %>
              </td>
              <td class="text-end">
                <button class="btn btn-link text-decoration-none text-danger p-0" onclick="confirmDeleteUser('<%= member.id %>', '<%= member.name.replace(/'/g, "\\'") %>')">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Team Member Modal -->
<div class="modal fade" id="addTeamModal" tabindex="-1" aria-labelledby="addTeamModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="addTeamModalLabel">Add Team Member</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="addTeamError" class="alert alert-danger small py-2" style="display: none;"></div>
        
        <div class="form-check form-switch mb-3">
          <input class="form-check-input" type="checkbox" id="bulkAddTeamToggle" onchange="toggleBulkAddTeam()">
          <label class="form-check-label text-muted small fw-bold" for="bulkAddTeamToggle">BULK ADD MODE</label>
        </div>

        <div id="singleTeamMode">
          <div class="mb-3">
            <label for="memberName" class="form-label text-muted small fw-bold">FULL NAME <span class="text-danger">*</span></label>
            <input type="text" id="memberName" class="form-control" placeholder="e.g. John Doe">
          </div>
          <div class="mb-3">
            <label for="memberEmail" class="form-label text-muted small fw-bold">EMAIL ADDRESS <span class="text-danger">*</span></label>
            <input type="email" id="memberEmail" class="form-control" placeholder="e.g. john@company.com">
          </div>
        </div>

        <div id="bulkTeamMode" style="display: none;">
          <div class="mb-3">
            <label for="bulkTeamInput" class="form-label text-muted small fw-bold">TEAM MEMBERS (Name, Email) <span class="text-danger">*</span></label>
            <textarea id="bulkTeamInput" class="form-control" rows="6" placeholder="John Doe, john@company.com&#10;Jane Smith, jane@company.com"></textarea>
            <small class="text-muted d-block mt-1">One member per line, separated by a comma.</small>
          </div>
        </div>

        <div class="mb-3">
          <label for="memberRole" class="form-label text-muted small fw-bold">ROLE</label>
          <select id="memberRole" class="form-select">
            <option value="Member">Member</option>
            <option value="Admin">Admin</option>
            <option value="Owner">Owner</option>
          </select>
        </div>
        <p class="text-muted small mb-0"><i class="bi bi-info-circle"></i> New members will receive a Magic Link via email to join the workspace instantly.</p>
      </div>
      <div class="modal-footer border-top-0 pt-0">
        <button type="button" class="btn btn-link text-decoration-none text-dark fw-medium" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-dark" onclick="submitAddTeam()">Add Member(s)</button>
      </div>
    </div>
  </div>
</div>

<!-- Delete User Modal -->
<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 450px;">
    <div class="modal-content">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="deleteUserModalLabel">Delete Team Member?</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body py-3">
        <div id="deleteUserDetails" class="fw-bold mb-2" style="color: #111;"></div>
        <p class="text-muted small mb-0">Are you sure you want to delete this team member? This will permanently affect tasks assigned to them.</p>
      </div>
      <div class="modal-footer border-top-0 pt-0 justify-content-end gap-2">
        <button type="button" class="btn btn-link text-decoration-none text-dark fw-medium" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger px-3 py-2 fw-medium text-white" style="border-radius: 8px;" onclick="executeDeleteUser()">Delete Member</button>
      </div>
    </div>
  </div>
</div>

<script>
  let activeDeleteUserId = null;
  let deleteUserModalObj = null;
  let addTeamModalObj = null;

  function confirmDeleteUser(userId, userName) {
    activeDeleteUserId = userId;
    document.getElementById('deleteUserDetails').innerText = userName;
    if (!deleteUserModalObj) {
      deleteUserModalObj = new bootstrap.Modal(document.getElementById('deleteUserModal'));
    }
    deleteUserModalObj.show();
  }

  async function executeDeleteUser() {
    if (!activeDeleteUserId) return;
    try {
      const ids = Array.isArray(activeDeleteUserId) ? activeDeleteUserId : [activeDeleteUserId];
      for (const id of ids) {
        const response = await fetch(`/team/${id}`, { method: 'DELETE' });
        if (!response.ok) {
          const data = await response.json();
          throw new Error(data.error || 'Failed to delete member');
        }
      }
      deleteUserModalObj.hide();
      window.location.reload();
    } catch (err) {
      console.error(err);
      alert(err.message);
    }
  }

  function confirmBulkDeleteUsers() {
    const checked = document.querySelectorAll('.row-checkbox:checked');
    if (checked.length === 0) return;
    const ids = Array.from(checked).map(cb => cb.value);
    activeDeleteUserId = ids;
    document.getElementById('deleteUserDetails').innerText = `${ids.length} member(s) selected`;
    if (!deleteUserModalObj) {
      deleteUserModalObj = new bootstrap.Modal(document.getElementById('deleteUserModal'));
    }
    deleteUserModalObj.show();
  }

  function toggleBulkAddTeam() {
    const isBulk = document.getElementById('bulkAddTeamToggle').checked;
    document.getElementById('singleTeamMode').style.display = isBulk ? 'none' : 'block';
    document.getElementById('bulkTeamMode').style.display = isBulk ? 'block' : 'none';
  }

  async function submitAddTeam() {
    const roleInput = document.getElementById('memberRole');
    const errorDiv = document.getElementById('addTeamError');
    const isBulk = document.getElementById('bulkAddTeamToggle').checked;
    
    const role = roleInput.value;
    errorDiv.style.display = 'none';

    let payload = {};
    let url = '';
    
    if (isBulk) {
      const bulkInput = document.getElementById('bulkTeamInput').value;
      const lines = bulkInput.split('\\n').map(l => l.trim()).filter(l => l);
      if (lines.length === 0) {
        errorDiv.innerText = 'Please enter at least one team member.';
        errorDiv.style.display = 'block';
        return;
      }
      
      const members = [];
      for (const line of lines) {
        const parts = line.split(',');
        if (parts.length < 2) {
          errorDiv.innerText = 'Invalid format. Use "Name, Email" on each line.';
          errorDiv.style.display = 'block';
          return;
        }
        members.push({
          name: parts[0].trim(),
          email: parts[1].trim()
        });
      }
      
      payload = { members, role };
      url = '/api/team/bulk';
    } else {
      const name = document.getElementById('memberName').value.trim();
      const email = document.getElementById('memberEmail').value.trim();
      if (!name || !email) {
        errorDiv.innerText = 'Name and Email are required.';
        errorDiv.style.display = 'block';
        return;
      }
      payload = { name, email, role };
      url = '/api/team';
    }
    
    try {
      const response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      
      const data = await response.json();
      if (response.ok) {
        if (!addTeamModalObj) {
          addTeamModalObj = bootstrap.Modal.getInstance(document.getElementById('addTeamModal'));
        }
        addTeamModalObj?.hide();
        window.location.reload();
      } else {
        errorDiv.innerText = data.error || 'Failed to add team member(s).';
        errorDiv.style.display = 'block';
      }
    } catch (err) {
      console.error(err);
      errorDiv.innerText = 'Server error. Please try again.';
      errorDiv.style.display = 'block';
    }
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    addTeamModalObj = new bootstrap.Modal(document.getElementById('addTeamModal'));
    
    // Reactive Search
    const searchInput = document.getElementById('teamSearch');
    const rows = document.querySelectorAll('.team-row');
    
    if (searchInput) {
      searchInput.addEventListener('keyup', (e) => {
        const term = e.target.value.toLowerCase();
        rows.forEach(row => {
          const text = row.textContent.toLowerCase();
          if (text.includes(term)) {
            row.style.display = '';
          } else {
            row.style.display = 'none';
          }
        });
      });
    }

    // Enter key support for modal inputs
    const memberNameInput = document.getElementById('memberName');
    const memberEmailInput = document.getElementById('memberEmail');
    
    function handleEnter(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        submitAddTeam();
      }
    }

    if (memberNameInput) memberNameInput.addEventListener('keypress', handleEnter);
    if (memberEmailInput) memberEmailInput.addEventListener('keypress', handleEnter);
  });

  let currentSortCol = -1;
  let currentSortDir = 'asc';
  
  function sortTable(n) {
    const table = document.querySelector(".table");
    const tbody = table.querySelector("tbody");
    const rows = Array.from(tbody.querySelectorAll("tr"));
    
    // Ignore if empty state
    if (rows.length === 0 || rows[0].querySelector("td[colspan]")) return;

    if (currentSortCol === n) {
      currentSortDir = currentSortDir === 'asc' ? 'desc' : 'asc';
    } else {
      currentSortCol = n;
      currentSortDir = 'asc';
    }

    rows.sort((a, b) => {
      const aText = a.cells[n].innerText.toLowerCase();
      const bText = b.cells[n].innerText.toLowerCase();
      
      if (aText < bText) return currentSortDir === 'asc' ? -1 : 1;
      if (aText > bText) return currentSortDir === 'asc' ? 1 : -1;
      return 0;
    });

    // Re-append sorted rows (efficiently moves them)
    tbody.append(...rows);
  }
</script>
