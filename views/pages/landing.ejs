<script>
  document.addEventListener('DOMContentLoaded', () => {
    const pricingToggle = document.getElementById('pricingToggle');
    const priceVals = document.querySelectorAll('.price-val');
    const priceSuffixes = document.querySelectorAll('.price-suffix');
    const monthlyLabel = document.getElementById('monthlyLabel');
    const annualLabel = document.getElementById('annualLabel');

    if (pricingToggle) {
      pricingToggle.addEventListener('change', (e) => {
        const isAnnual = e.target.checked;
        
        if (isAnnual) {
          monthlyLabel.classList.replace('text-dark', 'text-muted');
          monthlyLabel.classList.remove('fw-bold');
          annualLabel.classList.replace('text-muted', 'text-dark');
          annualLabel.classList.add('fw-bold');
        } else {
          annualLabel.classList.replace('text-dark', 'text-muted');
          annualLabel.classList.remove('fw-bold');
          monthlyLabel.classList.replace('text-muted', 'text-dark');
          monthlyLabel.classList.add('fw-bold');
        }

        priceVals.forEach(el => {
          el.innerText = isAnnual ? el.getAttribute('data-annual') : el.getAttribute('data-monthly');
        });
        
        priceSuffixes.forEach(el => {
          el.innerText = isAnnual ? '/yr' : '/mo';
        });
      });
    }
  });
</script>

