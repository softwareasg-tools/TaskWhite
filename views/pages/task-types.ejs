<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <div class="section-subtitle">MASTER DATA</div>
    <h1 class="page-title mb-0">Tasks</h1>
  </div>
  <div class="d-flex gap-3">
    <div class="input-group">
      <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
      <input type="text" id="taskTypeSearch" class="form-control border-start-0 ps-0" placeholder="Search tasks...">
    </div>
    <button class="btn btn-outline-primary text-nowrap" data-bs-toggle="modal" data-bs-target="#generateAIModal"><i class="bi bi-magic me-1"></i> Auto-Generate via AI</button>
    <button class="btn btn-dark text-nowrap" data-bs-toggle="modal" data-bs-target="#addTaskTypeModal"><i class="bi bi-plus"></i> Add Task</button>
  </div>
</div>

<div id="bulkActionBar" class="bulk-action-bar">
  <div class="fw-bold"><span id="bulkSelectedCount">0 selected</span></div>
  <button class="btn btn-danger btn-sm" onclick="confirmBulkDeleteTaskTypes()">
    <i class="bi bi-trash"></i> Delete Selected
  </button>
</div>

<div class="card" style="max-width: 600px;">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="bg-light">
          <tr>
            <th style="width: 40px;"><input type="checkbox" class="form-check-input master-checkbox" onchange="toggleAllCheckboxes(event)"></th>
            <th onclick="sortTable(1)" style="cursor: pointer;">Task Name <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (taskTypes.length === 0) { %>
            <tr><td colspan="3" class="text-center text-muted p-4">No tasks found.</td></tr>
          <% } %>
          <% taskTypes.forEach(type => { %>
            <tr class="task-type-row">
              <td><input type="checkbox" class="form-check-input row-checkbox" value="<%= type.id %>" onchange="updateBulkDeleteAction()"></td>
              <td>
                <i class="bi bi-tag text-muted me-2"></i>
                <span class="fw-bold task-type-name"><%= type.name %></span>
              </td>
              <td class="text-end">
                <button class="btn btn-link text-decoration-none text-danger p-0" onclick="confirmDeleteTaskType('<%= type.id %>', '<%= type.name.replace(/'/g, "\\'") %>')">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Task Type Modal -->
<div class="modal fade" id="addTaskTypeModal" tabindex="-1" aria-labelledby="addTaskTypeModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 450px;">
    <div class="modal-content">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="addTaskTypeModalLabel">Add Task</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="addTaskTypeError" class="alert alert-danger small py-2" style="display: none;"></div>
        
        <div class="form-check form-switch mb-3">
          <input class="form-check-input" type="checkbox" id="bulkAddTaskTypeToggle" onchange="toggleBulkAddTaskType()">
          <label class="form-check-label text-muted small fw-bold" for="bulkAddTaskTypeToggle">BULK ADD MODE</label>
        </div>

        <div id="singleTaskTypeMode">
          <div class="mb-3">
            <label for="taskTypeNameInput" class="form-label text-muted small fw-bold">TASK NAME <span class="text-danger">*</span></label>
            <input type="text" id="taskTypeNameInput" class="form-control" placeholder="e.g. Video Editing">
          </div>
        </div>

        <div id="bulkTaskTypeMode" style="display: none;">
          <div class="mb-3">
            <label for="bulkTaskTypeInput" class="form-label text-muted small fw-bold">TASK NAMES (ONE PER LINE) <span class="text-danger">*</span></label>
            <textarea id="bulkTaskTypeInput" class="form-control" rows="6" placeholder="Video Editing&#10;Logo Design&#10;Copywriting"></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer border-top-0 pt-0">
        <button type="button" class="btn btn-link text-decoration-none text-dark fw-medium" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-dark" onclick="submitAddTaskType()">Add Task(s)</button>
      </div>
    </div>
  </div>
</div>

<!-- AI Generation Modal -->
<div class="modal fade" id="generateAIModal" tabindex="-1" aria-labelledby="generateAIModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 450px;">
    <div class="modal-content border-primary" style="box-shadow: 0 0 20px rgba(13, 110, 253, 0.15);">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold text-primary" id="generateAIModalLabel"><i class="bi bi-magic me-2"></i>AI Task Generator</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="aiGenerateError" class="alert alert-danger small py-2" style="display: none;"></div>
        
        <p class="text-muted small mb-3">Save hours of setup! Let AI automatically populate standard tasks for your specific industry.</p>
        
        <div class="mb-3">
          <label for="aiIndustryInput" class="form-label text-muted small fw-bold">YOUR INDUSTRY <span class="text-danger">*</span></label>
          <input type="text" id="aiIndustryInput" class="form-control form-control-lg" placeholder="e.g. Law Firm, Architecture, Podcast Agency">
        </div>
      </div>
      <div class="modal-footer border-top-0 pt-0">
        <button type="button" class="btn btn-link text-decoration-none text-dark fw-medium" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="aiGenerateBtn" onclick="generateTasksWithAI()">Generate Tasks</button>
      </div>
    </div>
  </div>
</div>

<!-- Delete Task Type Modal -->
<div class="modal fade" id="deleteTaskTypeModal" tabindex="-1" aria-labelledby="deleteTaskTypeModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 450px;">
    <div class="modal-content">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="deleteTaskTypeModalLabel">Delete Task?</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body py-3">
        <div id="deleteTaskTypeDetails" class="fw-bold mb-2" style="color: #111;"></div>
        <p class="text-muted small mb-0">Are you sure you want to delete this task? This will permanently affect dashboard tasks using it.</p>
      </div>
      <div class="modal-footer border-top-0 pt-0 justify-content-end gap-2">
        <button type="button" class="btn btn-link text-decoration-none text-dark fw-medium" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger px-3 py-2 fw-medium text-white" style="border-radius: 8px;" onclick="executeDeleteTaskType()">Delete Task</button>
      </div>
    </div>
  </div>
</div>

<script>
  let activeDeleteTaskTypeId = null;
  let deleteTaskTypeModalObj = null;
  let addTaskTypeModalObj = null;
  let currentGeneratedIndustry = '';

  function confirmDeleteTaskType(id, name) {
    activeDeleteTaskTypeId = id;
    document.getElementById('deleteTaskTypeDetails').innerText = name;
    if (!deleteTaskTypeModalObj) {
      deleteTaskTypeModalObj = new bootstrap.Modal(document.getElementById('deleteTaskTypeModal'));
    }
    deleteTaskTypeModalObj.show();
  }

  async function executeDeleteTaskType() {
    if (!activeDeleteTaskTypeId) return;
    try {
      const ids = Array.isArray(activeDeleteTaskTypeId) ? activeDeleteTaskTypeId : [activeDeleteTaskTypeId];
      
      for (const id of ids) {
        const response = await fetch(`/task-types/${id}`, { method: 'DELETE' });
        if (!response.ok) {
          const data = await response.json();
          throw new Error(data.error || 'Failed to delete task');
        }
      }
      
      deleteTaskTypeModalObj.hide();
      window.location.reload();
    } catch (err) {
      console.error(err);
      alert(err.message);
    }
  }

  function confirmBulkDeleteTaskTypes() {
    const checked = document.querySelectorAll('.row-checkbox:checked');
    if (checked.length === 0) return;
    const ids = Array.from(checked).map(cb => cb.value);
    activeDeleteTaskTypeId = ids;
    document.getElementById('deleteTaskTypeDetails').innerText = `${ids.length} item(s) selected`;
    if (!deleteTaskTypeModalObj) {
      deleteTaskTypeModalObj = new bootstrap.Modal(document.getElementById('deleteTaskTypeModal'));
    }
    deleteTaskTypeModalObj.show();
  }

  function toggleBulkAddTaskType() {
    const isBulk = document.getElementById('bulkAddTaskTypeToggle').checked;
    document.getElementById('singleTaskTypeMode').style.display = isBulk ? 'none' : 'block';
    document.getElementById('bulkTaskTypeMode').style.display = isBulk ? 'block' : 'none';
    if (!isBulk) currentGeneratedIndustry = ''; // Clear tracking if they toggle off bulk
  }

  async function submitAddTaskType() {
    const errorDiv = document.getElementById('addTaskTypeError');
    const isBulk = document.getElementById('bulkAddTaskTypeToggle').checked;
    
    errorDiv.style.display = 'none';
    
    let payload = {};
    let url = '';

    if (isBulk) {
      const bulkInput = document.getElementById('bulkTaskTypeInput').value;
      const names = bulkInput.split('\n').map(n => n.trim()).filter(n => n);
      if (names.length === 0) {
        errorDiv.innerText = 'Please enter at least one task type name.';
        errorDiv.style.display = 'block';
        return;
      }
      payload = { names };
      if (currentGeneratedIndustry) payload.aiIndustry = currentGeneratedIndustry;
      url = '/api/task-types/bulk';
    } else {
      const name = document.getElementById('taskTypeNameInput').value.trim();
      if (!name) {
        errorDiv.innerText = 'Task type name is required.';
        errorDiv.style.display = 'block';
        return;
      }
      payload = { name };
      url = '/api/task-types';
    }
    
    try {
      const response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      
      const data = await response.json();
      if (response.ok) {
        if (!addTaskTypeModalObj) {
          addTaskTypeModalObj = bootstrap.Modal.getInstance(document.getElementById('addTaskTypeModal'));
        }
        addTaskTypeModalObj?.hide();
        window.location.reload();
      } else {
        errorDiv.innerText = data.error || 'Failed to add task type(s).';
        errorDiv.style.display = 'block';
      }
    } catch (err) {
      console.error(err);
      errorDiv.innerText = 'Server error. Please try again.';
      errorDiv.style.display = 'block';
    }
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    addTaskTypeModalObj = new bootstrap.Modal(document.getElementById('addTaskTypeModal'));
    
    // Reactive Search
    const searchInput = document.getElementById('taskTypeSearch');
    const rows = document.querySelectorAll('.task-type-row');
    
    if (searchInput) {
      searchInput.addEventListener('keyup', (e) => {
        const term = e.target.value.toLowerCase();
        rows.forEach(row => {
          const name = row.querySelector('.task-type-name').textContent.toLowerCase();
          if (name.includes(term)) {
            row.style.display = '';
          } else {
            row.style.display = 'none';
          }
        });
      });
    }

    // Enter key support for modal inputs
    const taskTypeNameInput = document.getElementById('taskTypeNameInput');
    if (taskTypeNameInput) {
      taskTypeNameInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          submitAddTaskType();
        }
      });
    }

    const aiIndustryInput = document.getElementById('aiIndustryInput');
    if (aiIndustryInput) {
      aiIndustryInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          generateTasksWithAI();
        }
      });
    }
  });

  async function generateTasksWithAI() {
    const industry = document.getElementById('aiIndustryInput').value.trim();
    const btn = document.getElementById('aiGenerateBtn');
    const errorDiv = document.getElementById('aiGenerateError');
    
    if (!industry) {
      errorDiv.innerText = 'Please enter an industry.';
      errorDiv.style.display = 'block';
      return;
    }
    
    try {
      errorDiv.style.display = 'none';
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Generating...';
      
      const res = await fetch('/api/ai/generate-tasks', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ industry })
      });
      
      const data = await res.json();
      
      if (res.ok) {
        // Hide AI modal
        bootstrap.Modal.getInstance(document.getElementById('generateAIModal')).hide();
        
        // Setup Warning Alert in Add Modal if they switched industries
        const addErrorDiv = document.getElementById('addTaskTypeError');
        if (data.lastIndustry && data.lastIndustry.toLowerCase() !== industry.toLowerCase() && document.querySelectorAll('.task-type-row').length > 0) {
          addErrorDiv.innerHTML = `<strong>Warning:</strong> You previously generated tasks for a <strong>${data.lastIndustry}</strong>. Are you sure you want to proceed with adding tasks for a <strong>${industry}</strong>?`;
          addErrorDiv.classList.replace('alert-danger', 'alert-warning');
          addErrorDiv.style.display = 'block';
        } else {
          addErrorDiv.style.display = 'none';
          addErrorDiv.classList.replace('alert-warning', 'alert-danger');
        }

        // Open Add Task Type modal in Bulk mode to review
        currentGeneratedIndustry = industry;
        document.getElementById('bulkAddTaskTypeToggle').checked = true;
        toggleBulkAddTaskType();
        document.getElementById('bulkTaskTypeInput').value = data.tasks.join('\n');
        
        if (!addTaskTypeModalObj) {
          addTaskTypeModalObj = new bootstrap.Modal(document.getElementById('addTaskTypeModal'));
        }
        addTaskTypeModalObj.show();
      } else {
        throw new Error(data.error || 'Failed to generate tasks.');
      }
    } catch (err) {
      console.error(err);
      errorDiv.innerText = err.message || 'Server error.';
      errorDiv.style.display = 'block';
    } finally {
      btn.disabled = false;
      btn.innerText = 'Generate Tasks';
    }
  }

  let currentSortCol = -1;
  let currentSortDir = 'asc';
  
  function sortTable(n) {
    const table = document.querySelector(".table");
    const tbody = table.querySelector("tbody");
    const rows = Array.from(tbody.querySelectorAll("tr"));
    
    // Ignore if empty state
    if (rows.length === 0 || rows[0].querySelector("td[colspan]")) return;

    if (currentSortCol === n) {
      currentSortDir = currentSortDir === 'asc' ? 'desc' : 'asc';
    } else {
      currentSortCol = n;
      currentSortDir = 'asc';
    }

    rows.sort((a, b) => {
      const aText = a.cells[n].innerText.toLowerCase();
      const bText = b.cells[n].innerText.toLowerCase();
      
      if (aText < bText) return currentSortDir === 'asc' ? -1 : 1;
      if (aText > bText) return currentSortDir === 'asc' ? 1 : -1;
      return 0;
    });

    tbody.append(...rows);
  }
</script>
