<div class="mb-4">
  <div class="section-subtitle">SETTINGS</div>
  <h1 class="page-title">Workspace Settings</h1>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-12">
    <div class="card">
      <div class="card-header">User Profile</div>
      <div class="card-body">
        <form id="profileForm" onsubmit="event.preventDefault(); updateProfile();">
          <div class="mb-3">
            <label class="form-label text-muted small fw-bold">DISPLAY NAME</label>
            <input type="text" class="form-control" id="profileName" value="<%= user.name %>">
          </div>
          <div class="mb-3">
            <label class="form-label text-muted small fw-bold">EMAIL ADDRESS</label>
            <input type="email" class="form-control" value="<%= user.email %>" disabled>
          </div>
          <button type="submit" class="btn btn-dark">Update Profile</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  async function updateProfile() {
    const name = document.getElementById('profileName').value.trim();
    if (!name) return showToast('Name cannot be empty', 'danger');

    try {
      const btn = document.querySelector('#profileForm .btn');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Updating...';
      btn.disabled = true;

      const response = await fetch('/settings/profile', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name })
      });
      
      const data = await response.json();
      if (response.ok) {
        showToast('Profile updated successfully!', 'success');
        reloadWithSuccess('Action completed successfully!');
      } else {
        showToast(data.error || 'Failed to update profile', 'danger');
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    } catch (err) {
      console.error(err);
      showToast('Network error while updating profile', 'danger');
      const btn = document.querySelector('#profileForm .btn');
      btn.innerHTML = 'Update Profile';
      btn.disabled = false;
    }
  }
</script>

<div class="row g-4">
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header">Organization Details</div>
      <div class="card-body">
        <form>
          <div class="mb-3">
            <label class="form-label text-muted small fw-bold">ORGANIZATION NAME</label>
            <input type="text" class="form-control" value="<%= org.name %>">
          </div>
          <button type="button" class="btn btn-dark">Update Name</button>
        </form>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header">Licensing & Billing</div>
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label text-muted small fw-bold">CURRENT PLAN</label>
          <p class="fs-5 mb-0"><span class="badge bg-dark text-white"><%= org.billing_plan %></span></p>
        </div>
        <div class="d-flex justify-content-between mb-2 text-muted small fw-bold">
          <span>SEATS USED</span>
          <span><%= usedSeats %> / <%= org.purchased_seats %></span>
        </div>
        <div class="progress mb-4" style="height: 10px; border-radius: 5px;">
          <div class="progress-bar bg-success" role="progressbar" style="width: <%= (usedSeats / org.purchased_seats) * 100 %>%"></div>
        </div>
        <button class="btn btn-outline-secondary w-100">Manage Subscription</button>
      </div>
    </div>
  </div>
</div>
