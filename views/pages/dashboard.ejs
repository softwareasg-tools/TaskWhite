<% 
  let activeFilterCount = 0;
  if(query.time) activeFilterCount++;
  if(query.client_id) activeFilterCount++;
  if(query.user_id) activeFilterCount++;
  if(query.task_type_id) activeFilterCount++;
  if(query.tag) activeFilterCount++;
%>
<div class="d-flex flex-wrap justify-content-between align-items-end mb-4 gap-3">
  <div class="d-none d-md-flex flex-wrap align-items-end gap-3">
    <div>
      <div class="section-subtitle">OVERVIEW</div>
      <h1 class="page-title mb-0">Dashboard</h1>
    </div>
    <div class="btn-group shadow-sm mb-1" style="height: fit-content;">
      <button class="btn btn-sm btn-dark btnListView" onclick="switchTaskView('list')"><i class="bi bi-list-ul"></i> List</button>
      <button class="btn btn-sm btn-outline-secondary btnCalendarView" onclick="switchTaskView('calendar')"><i class="bi bi-calendar3"></i> Calendar</button>
    </div>
  </div>
  <div class="d-flex align-items-center gap-2 w-100 w-md-auto justify-content-center justify-content-md-start">
    <% if (!user.view_access || user.view_access === 'org_and_my') { %>
    <div class="btn-group shadow-sm mb-1" role="group">
      <a href="?<%= new URLSearchParams({...query, view: 'org'}).toString() %>" class="btn btn-sm <%= !query.view || query.view === 'org' ? 'btn-dark' : 'btn-outline-secondary' %>">Org View</a>
      <a href="?<%= new URLSearchParams({...query, view: 'my'}).toString() %>" class="btn btn-sm <%= query.view === 'my' ? 'btn-dark' : 'btn-outline-secondary' %>">My View</a>
    </div>
    <% } else { %>
      <div class="btn-group shadow-sm mb-1" role="group">
        <a href="#" class="btn btn-sm btn-dark">My View</a>
      </div>
    <% } %>
  </div>
</div>


<!-- Main Layout Row -->
<div class="row">
  <!-- Sidebar Filters -->
  <div class="col-lg-3 col-xl-2 mb-4 d-none d-lg-block">
    <div class="card border-0 shadow-sm sticky-top" style="top: 80px; max-height: calc(100vh - 100px); overflow-y: auto; background-color: var(--card-bg);">
      <div class="card-header bg-transparent border-bottom fw-bold text-uppercase py-3" style="letter-spacing: 0.5px; font-size: 0.85rem;">
        <i class="bi bi-funnel-fill text-primary me-2"></i> Filters
        <% if (activeFilterCount > 0) { %>
          <span class="badge bg-primary ms-1"><%= activeFilterCount %></span>
          <a href="/dashboard<%= query.view ? '?view=' + query.view : '' %>" class="float-end text-decoration-none small text-muted text-capitalize" style="font-size: 0.75rem;">Reset</a>
        <% } %>
      </div>
      <div class="card-body p-3" id="sidebarFiltersContainer">
        <form id="filterForm" method="GET" action="/dashboard" onchange="submitDashboardFilters()">
          <% if (query.view) { %>
            <input type="hidden" name="view" value="<%= query.view %>">
          <% } %>
          
          <div class="mb-4">
            <label class="form-label fw-bold  small">Time Period</label>
            <select name="time" id="timeFilterSelect" class="form-select form-select-sm" onchange="toggleCustomDateFields()">
              <option value="">All Time</option>
              <option value="today" <%= query.time === 'today' ? 'selected' : '' %>>Today</option>
              <option value="7days" <%= query.time === '7days' ? 'selected' : '' %>>Next 7 Days</option>
              <option value="15days" <%= query.time === '15days' ? 'selected' : '' %>>Next 15 Days</option>
              <option value="30days" <%= query.time === '30days' ? 'selected' : '' %>>Next 30 Days</option>
              <option value="60days" <%= query.time === '60days' ? 'selected' : '' %>>Next 60 Days</option>
              <option value="90days" <%= query.time === '90days' ? 'selected' : '' %>>Next 90 Days</option>
              <option value="custom" <%= query.time === 'custom' ? 'selected' : '' %>>Custom Date</option>
            </select>
            
            <div id="customDateFields" class="mt-2 p-2 bg-light rounded" style="display: <%= query.time === 'custom' ? 'block' : 'none' %>;">
              <div class="mb-2">
                <label class="text-muted" style="font-size:0.7rem;">START DATE</label>
                <input type="text" id="filter_start_date" name="start_date" class="form-control form-control-sm" placeholder="Select Date" value="<%= query.start_date || '' %>">
              </div>
              <div>
                <label class="text-muted" style="font-size:0.7rem;">END DATE</label>
                <input type="text" id="filter_end_date" name="end_date" class="form-control form-control-sm" placeholder="Select Date" value="<%= query.end_date || '' %>">
              </div>
            </div>
          </div>
          
          <hr class="text-muted opacity-25">
          
          <div class="mb-4">
            <label class="form-label fw-bold  small">Clients</label>
            <select name="client_id" class="form-select form-select-sm">
              <option value="">All Clients</option>
              <% clients.forEach(client => { %>
                <option value="<%= client.id %>" <%= query.client_id == client.id ? 'selected' : '' %>><%= client.name %></option>
              <% }) %>
            </select>
          </div>
          
          <hr class="text-muted opacity-25">
          
          <div class="mb-4">
            <label class="form-label fw-bold  small">Team Members</label>
            <select name="user_id" class="form-select form-select-sm">
              <option value="">All Members</option>
              <% users.forEach(u => { %>
                <option value="<%= u.id %>" <%= query.user_id == u.id ? 'selected' : '' %>><%= u.name %></option>
              <% }) %>
            </select>
          </div>
          
          <hr class="text-muted opacity-25">
          
          <div class="mb-4">
            <label class="form-label fw-bold  small">Task Types</label>
            <select name="task_type_id" class="form-select form-select-sm">
              <option value="">All Tasks</option>
              <% taskTypes.forEach(type => { %>
                <option value="<%= type.id %>" <%= query.task_type_id == type.id ? 'selected' : '' %>><%= type.name %></option>
              <% }) %>
            </select>
          </div>

          <hr class="text-muted opacity-25">

          <div class="mb-4">
            <label class="form-label fw-bold  small">Status</label>
            <select name="status" class="form-select form-select-sm" onchange="submitDashboardFilters()">
              <option value="">All Statuses</option>
              <option value="Assigned" <%= query.status === 'Assigned' ? 'selected' : '' %>>Assigned</option>
              <option value="In Progress" <%= query.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
              <option value="Completed" <%= query.status === 'Completed' ? 'selected' : '' %>>Completed</option>
              <option value="Overdue" <%= query.status === 'Overdue' ? 'selected' : '' %>>Overdue</option>
            </select>
          </div>
          
          <hr class="text-muted opacity-25">
          
          <div class="mb-2">
            <label class="form-label fw-bold  small">Tags</label>
            <select name="tag" class="form-select form-select-sm">
              <option value="">All Tags</option>
              <% availableTags.forEach(tag => { %>
                <option value="<%= tag %>" <%= query.tag === tag ? 'selected' : '' %>><%= tag %></option>
              <% }) %>
            </select>
          </div>

          <!-- Hidden Submit Button (triggered via JS) -->
          <button type="submit" class="d-none">Apply</button>
        </form>
      </div>
    </div>
  </div>
  
  <!-- Main Content Area -->
  <div class="col-lg-9 col-xl-10" id="mainDashboardContent">
<!-- KPIs -->
<div class="row g-3 mb-4">
  <div class="col-6 col-sm-6 col-xl">
    <div class="card h-100">
      <div class="card-header">Total Tasks</div>
      <div class="card-body">
        <div class="stat-value"><%= stats.totalTasks %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-sm-6 col-xl">
    <div class="card h-100">
      <div class="card-header">Assigned</div>
      <div class="card-body">
        <div class="stat-value" style="color: #f06a2f;"><%= stats.assigned %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-sm-6 col-xl">
    <div class="card h-100">
      <div class="card-header">In Progress</div>
      <div class="card-body">
        <div class="stat-value" style="color: #1a73e8;"><%= stats.inProgress %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-sm-6 col-xl">
    <div class="card h-100">
      <div class="card-header">Completed</div>
      <div class="card-body">
        <div class="stat-value" style="color: #1e8e3e;"><%= stats.completed %></div>
      </div>
    </div>
  </div>
  <div class="col-12 col-sm-6 col-xl">
    <div class="card h-100">
      <div class="card-header">Overdue</div>
      <div class="card-body">
        <div class="stat-value" style="color: #d93025;"><%= stats.overdue %></div>
      </div>
    </div>
  </div>
</div>

<!-- Charts (Collapsible globally) -->
<style>
  button[aria-expanded="true"] .toggle-icon {
    transform: rotate(180deg);
  }
  .transition-transform {
    transition: transform 0.3s ease;
  }
  .keyboard-focused {
    background-color: rgba(0, 0, 0, 0.05) !important;
    outline: 2px solid var(--bs-primary);
    outline-offset: -2px;
  }
  [data-bs-theme="dark"] .keyboard-focused {
    background-color: rgba(255, 255, 255, 0.1) !important;
  }
  .task-selected {
    background-color: rgba(135, 206, 235, 0.2) !important;
  }
  [data-bs-theme="dark"] .task-selected {
    background-color: rgba(135, 206, 235, 0.15) !important;
  }
  .task-complete-anim {
    background-image: linear-gradient(to right, skyblue 50%, transparent 50%) !important;
    background-size: 200% 100% !important;
    background-position: right bottom !important;
    animation: fillSkyBlue 0.5s ease-out forwards !important;
  }
  .task-complete-anim td,
  .task-complete-anim th {
    background-color: transparent !important;
    --bs-table-bg: transparent;
    --bs-table-accent-bg: transparent;
    --bs-table-striped-bg: transparent;
  }
  .task-complete-anim-fadeout {
    background-color: skyblue !important;
    animation: fadeOutWhite 2s ease-out forwards !important;
  }
  .task-complete-anim-fadeout td,
  .task-complete-anim-fadeout th {
    background-color: transparent !important;
    --bs-table-bg: transparent;
    --bs-table-accent-bg: transparent;
  }
  .task-highlight-anim {
    background-color: #d4edda !important;
    transition: background-color 1s ease-out;
  }
  .task-highlight-anim td,
  .task-highlight-anim th {
    background-color: transparent !important;
    --bs-table-bg: transparent;
    --bs-table-accent-bg: transparent;
    --bs-table-striped-bg: transparent;
  }
  .task-linger-blue-anim {
    background-color: rgba(135, 206, 235, 0.4) !important;
    transition: background-color 3s ease-out;
  }
  .task-linger-blue-anim td,
  .task-linger-blue-anim th {
    background-color: transparent !important;
    --bs-table-bg: transparent;
    --bs-table-accent-bg: transparent;
    --bs-table-striped-bg: transparent;
  }
  @keyframes fillSkyBlue {
    to { background-position: left bottom; }
  }
  @keyframes fadeOutWhite {
    from { background-color: skyblue; }
    to { background-color: transparent; }
  }
</style>
<div class="mb-4 d-flex align-items-center">
  <hr class="flex-grow-1 text-muted opacity-25 m-0">
  <button class="btn btn-outline-secondary btn-sm fw-bold mx-3 d-flex align-items-center gap-2 border" type="button" data-bs-toggle="collapse" data-bs-target="#analyticsCollapse" aria-expanded="false" aria-controls="analyticsCollapse" style="border-radius: 20px; padding: 6px 20px; font-size: 0.75rem; background-color: var(--card-bg);">
    <i class="bi bi-graph-up-arrow text-primary"></i> 
    <span>Analytics Dashboard</span>
    <i class="bi bi-chevron-down toggle-icon transition-transform"></i>
  </button>
  <hr class="flex-grow-1 text-muted opacity-25 m-0">
</div>

<div class="collapse" id="analyticsCollapse">
  <div class="row g-4 mb-5">
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header">Tasks by Status</div>
        <div class="card-body d-flex justify-content-center align-items-center" style="height: 300px;">
          <canvas id="statusChart"></canvas>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header fw-bold text-muted small">TASK COUNT BY TEAM MEMBER</div>
        <div class="card-body" style="height: 300px;">
          <canvas id="teamChart"></canvas>
        </div>
      </div>
    </div>
    <div class="col-md-12">
      <div class="card h-100">
        <div class="card-header fw-bold text-muted small">TASK COUNT</div>
        <div class="card-body" style="height: 400px;">
          <canvas id="typeChart"></canvas>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Tasks List (Combined View) -->
<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 mt-5 gap-3">
  <div class="d-flex flex-wrap align-items-end gap-3">
    <div>
      <div class="section-subtitle">WORKSPACE</div>
      <h1 class="page-title mb-0">Tasks</h1>
    </div>
    <div class="btn-group shadow-sm mb-1" style="height: fit-content;">
      <button class="btn btn-sm btn-dark btnListView" onclick="switchTaskView('list')"><i class="bi bi-list-ul"></i> List</button>
      <button class="btn btn-sm btn-outline-secondary btnCalendarView" onclick="switchTaskView('calendar')"><i class="bi bi-calendar3"></i> Calendar</button>
    </div>
  </div>
  <div class="d-flex flex-wrap gap-2 align-items-center">
    <div class="input-group" style="width: auto; flex-grow: 1; min-width: 200px;">
      <span class="input-group-text border-end-0" style="background-color: var(--card-bg);"><i class="bi bi-search text-muted"></i></span>
      <input type="text" id="dashboardSearch" class="form-control border-start-0 ps-0" placeholder="Search tasks..." style="background-color: var(--card-bg);">
    </div>
    <button type="button" class="btn btn-outline-secondary me-2 text-nowrap" onclick="exportExcel()"><i class="bi bi-file-earmark-excel"></i> Export Excel</button>
    <button type="button" class="btn btn-dark text-nowrap" data-bs-toggle="modal" data-bs-target="#newTaskModal"><i class="bi bi-plus"></i> New Task</button>
  </div>
</div>

<div id="bulkActionBar" class="bulk-action-bar" style="display: none;">
  <div class="fw-bold"><span id="bulkSelectedCount">0 selected</span></div>
  <button class="btn btn-danger btn-sm" onclick="confirmBulkDeleteDashboardTasks()">
    <i class="bi bi-trash"></i> Delete Selected
  </button>
</div>

<div id="listView" class="card mb-5 border-0 bg-transparent bg-md-surface border-md shadow-sm-md">
  <div class="card-body p-0 bg-transparent bg-md-surface">
    <!-- Desktop Table View -->
    <div class="table-responsive d-none d-md-block card-inner-desktop">
      <table class="table table-hover mb-0">
        <thead class="bg-light">
          <tr>
            <th style="width: 40px;"><input type="checkbox" class="form-check-input master-checkbox" onchange="toggleAllCheckboxes(event)"></th>
            <th onclick="sortTable(1)" style="cursor: pointer;">Client <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(1)" style="cursor: pointer;">Task <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(2)" style="cursor: pointer;">Assigned To <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(3)" style="cursor: pointer;">Due Date <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(4)" style="cursor: pointer;">Status <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortByActionDate()" class="text-end" style="cursor: pointer;">Actions <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
          </tr>
        </thead>
        <tbody>
          <% tasks.forEach(task => { 
               let timestamp = 0;
               if (task.updated_at && task.updated_at._seconds) timestamp = task.updated_at._seconds;
               else if (task.created_at && task.created_at._seconds) timestamp = task.created_at._seconds;
          %>
            <tr class="dashboard-task-row" onclick="if(!event.target.classList.contains('row-checkbox')) openTaskModal('<%= task.id %>')" data-timestamp="<%= timestamp %>">
              <td><input type="checkbox" class="form-check-input row-checkbox" value="<%= task.id %>" data-assigned="<%= task.assigned_user_id ? 'true' : 'false' %>" data-status="<%= task.status %>" onchange="updateBulkDeleteAction()"></td>
              <td class="fw-bold"><%= task.Client ? task.Client.name : '-' %></td>
              <td>
                <div class="fw-medium "><%= task.TaskType ? task.TaskType.name : '-' %></div>
                <% if (task.tags && task.tags.length > 0) { %>
                  <div class="mt-1 d-flex gap-1 flex-wrap">
                    <% task.tags.forEach(tag => { %>
                      <span class="badge bg-light text-secondary border px-2 py-1" style="font-size: 0.65rem;"><%= tag %></span>
                    <% }) %>
                  </div>
                <% } %>
              </td>
              <td><%= task.Assignee ? task.Assignee.name : '-' %></td>
              <td><%= formatAppDate(task.due_date) %></td>
              <td>
                <% if (task.status === 'Completed') { %>
                  <span class="badge badge-outline text-success border-success">Completed</span>
                <% } else if (task.status === 'In Progress') { %>
                  <span class="badge badge-outline text-primary border-primary">In Progress</span>
                <% } else if (task.status === 'Overdue') { %>
                  <span class="badge badge-outline text-danger border-danger">Overdue</span>
                <% } else { %>
                  <span class="badge badge-outline">Assigned</span>
                <% } %>
              </td>
              <td class="text-end">
                <i class="bi bi-pencil text-muted me-3"></i>
                <i class="bi bi-trash text-danger" onclick="deleteTask(event, '<%= task.id %>', '<%= (task.TaskType ? task.TaskType.name : `-`).replace(/\x27/g, '\\\'').replace(/\x22/g, '\\\"') %>', '<%= (task.Client ? task.Client.name : `-`).replace(/\x27/g, '\\\'').replace(/\x22/g, '\\\"') %>', <%= task.assigned_user_id ? 'true' : 'false' %>, '<%= task.status %>')" style="cursor: pointer;"></i>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Mobile Tile List View -->
    <div class="d-block d-md-none">
      <% if (tasks.length === 0) { %>
        <div class="text-center text-muted p-4 bg-surface rounded border">No tasks found.</div>
      <% } %>
      <div class="d-flex flex-column gap-3">
        <% tasks.forEach(task => { %>
          <% 
             const typeName = task.TaskType ? task.TaskType.name : '-';
             const clientName = task.Client ? task.Client.name : 'Internal';
             const assigneeName = task.Assignee ? task.Assignee.name : 'Unassigned';
             let badgeClass = 'text-muted border-secondary';
             if (task.status === 'Completed') badgeClass = 'text-success border-success';
             else if (task.status === 'Overdue') badgeClass = 'text-danger border-danger';
             else if (task.status === 'In Progress') badgeClass = 'text-primary border-primary';
          %>
          <div class="dashboard-task-row p-3 border rounded shadow-sm bg-surface" onclick="openTaskModal('<%= task.id %>')">
            <div class="d-flex justify-content-between align-items-start mb-1">
              <h6 class="fw-bold mb-0"><%= typeName %></h6>
              <span class="badge bg-transparent border <%= badgeClass %>" style="font-size: 0.65rem;"><%= task.status %></span>
            </div>
            <div class="opacity-75 small mb-2"><%= clientName %> &middot; <%= assigneeName %></div>
            <div class="d-flex justify-content-between align-items-center mt-2 border-top pt-2">
              <span class="opacity-75 small" style="font-size: 0.75rem;"><i class="bi bi-calendar-event me-1"></i><%= formatAppDate(task.due_date) %></span>
              <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary py-1 px-2" style="font-size: 0.7rem;" onclick="event.stopPropagation(); openTaskModal('<%= task.id %>')"><i class="bi bi-pencil"></i> Edit</button>
                <button class="btn btn-sm btn-outline-danger py-1 px-2" style="font-size: 0.7rem;" onclick="event.stopPropagation(); deleteTask(event, '<%= task.id %>', '<%= (task.TaskType ? task.TaskType.name : `-`).replace(/\x27/g, '\\\'').replace(/\x22/g, '\\\"') %>', '<%= (task.Client ? task.Client.name : `-`).replace(/\x27/g, '\\\'').replace(/\x22/g, '\\\"') %>', <%= task.assigned_user_id ? 'true' : 'false' %>, '<%= task.status %>')"><i class="bi bi-trash"></i> Delete</button>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>

<!-- Calendar View -->
<div id="calendarView" class="mb-5 d-none">
  <div class="row g-4">
    <!-- Calendar Grid -->
    <div class="col-lg-8">
      <div class="card h-100">
        <div class="card-header d-flex justify-content-between align-items-center">
          <button class="btn btn-sm btn-outline-secondary border-0" onclick="changeMonth(-1)"><i class="bi bi-chevron-left"></i></button>
          <span id="calendarMonthYear" class="fw-bold fs-5 "></span>
          <button class="btn btn-sm btn-outline-secondary border-0" onclick="changeMonth(1)"><i class="bi bi-chevron-right"></i></button>
        </div>
        <div class="card-body p-0">
          <div class="calendar-grid-header d-flex text-center text-muted fw-bold small py-2 border-bottom" style="background-color: #fafafa;">
            <div style="flex:1">SUN</div><div style="flex:1">MON</div><div style="flex:1">TUE</div><div style="flex:1">WED</div>
            <div style="flex:1">THU</div><div style="flex:1">FRI</div><div style="flex:1">SAT</div>
          </div>
          <div id="calendarGrid" class="d-flex flex-wrap" style="border-left: 1px solid var(--border-color);">
            <!-- Days injected via JS -->
          </div>
        </div>
      </div>
    </div>
    <!-- Selected Day Details -->
    <div class="col-lg-4">
      <div class="card h-100" style="background-color: var(--card-bg);">
        <div class="card-body">
          <div class="text-uppercase text-muted fw-bold small mb-1" style="letter-spacing: 1px;">SELECTED</div>
          <h4 id="selectedDayTitle" class="fw-bold mb-4">Select a day</h4>
          <div id="selectedDayTasks" class="d-flex flex-column gap-3">
            <!-- Tasks injected via JS -->
            <div class="text-muted small">Click on a day in the calendar to view scheduled tasks.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .calendar-day {
    flex: 0 0 calc(100% / 7);
    min-height: 120px;
    border-right: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    padding: 8px;
    cursor: pointer;
    transition: background-color 0.2s;
    display: flex;
    flex-direction: column;
  }
  @media (max-width: 767.98px) {
    .calendar-day {
      min-height: 60px;
      padding: 4px;
    }
  }
  .calendar-day:hover {
    background-color: rgba(0,0,0,0.02);
  }
