<div class="d-flex justify-content-between align-items-center mb-4">
  <div class="d-flex gap-3">
    <div class="input-group">
      <span class="input-group-text bg-surface border-end-0"><i class="bi bi-search text-muted"></i></span>
      <input type="text" id="tasksSearch" class="form-control border-start-0 ps-0" placeholder="Search tasks...">
    </div>
    <a href="/dashboard?action=new" class="btn btn-dark text-nowrap"><i class="bi bi-plus"></i> Add Task</a>
  </div>
</div>

<div id="bulkActionBar" class="bulk-action-bar" style="display: none;">
  <div class="fw-bold"><span id="bulkSelectedCount">0 selected</span></div>
  <button class="btn btn-danger btn-sm" onclick="confirmBulkDeleteTasks()">
    <i class="bi bi-trash"></i> Delete Selected
  </button>
</div>

<div class="card border-0 bg-transparent bg-md-surface border-md shadow-sm-md">
  <div class="card-body p-0 bg-transparent bg-md-surface">
    <!-- Desktop Table View -->
    <div class="table-responsive d-none d-md-block">
      <table class="table table-hover mb-0">
        <thead class="bg-light">
          <tr>
            <th style="width: 40px;"><input type="checkbox" class="form-check-input master-checkbox" onchange="toggleAllCheckboxes(event)"></th>
            <th onclick="sortTable(1)" style="cursor: pointer;">Client <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(2)" style="cursor: pointer;">Show <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(3)" style="cursor: pointer;">Episode <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(4)" style="cursor: pointer;">Task <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(5)" style="cursor: pointer;">Assigned To <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(6)" style="cursor: pointer;">Due Date <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(7)" style="cursor: pointer;">Status <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
            <th onclick="sortTable(8)" style="cursor: pointer;">Priority <i class="bi bi-arrow-down-up text-muted ms-1" style="font-size: 0.8em;"></i></th>
          </tr>
        </thead>
        <tbody>
          <% tasks.forEach(task => { %>
            <tr class="tasks-task-row" onclick="if(!event.target.classList.contains('row-checkbox')) openTaskModal('<%= task.id %>')">
              <td><input type="checkbox" class="form-check-input row-checkbox" value="<%= task.id %>" data-assigned="<%= task.assigned_user_id ? 'true' : 'false' %>" data-status="<%= task.status %>" onchange="updateBulkDeleteAction()"></td>
              <td><%= task.Client ? task.Client.name : '-' %></td>
              <td><%= task.show_name || '-' %></td>
              <td><%= task.episode_name || '-' %></td>
              <td><%= task.TaskType ? task.TaskType.name : '-' %></td>
              <td>
                <i class="bi bi-person-circle text-muted me-1"></i>
                <%= task.Assignee ? task.Assignee.name : '-' %>
              </td>
              <td><%= formatAppDate(task.due_date) %></td>
              <td>
                <% if (task.status === 'Completed') { %>
                  <span class="badge bg-success"><%= task.status %></span>
                <% } else if (task.status === 'In Progress') { %>
                  <span class="badge bg-warning"><%= task.status %></span>
                <% } else if (task.status === 'Overdue') { %>
                  <span class="badge bg-danger"><%= task.status %></span>
                <% } else { %>
                  <span class="badge bg-primary"><%= task.status %></span>
                <% } %>
              </td>
              <td>
                <% if (task.priority === 'High') { %>
                  <span class="text-danger fw-bold"><i class="bi bi-exclamation-circle"></i> High</span>
                <% } else { %>
                  <span class="text-muted">Normal</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    
    <!-- Mobile Tile View -->
    <div class="d-block d-md-none">
      <% if (tasks.length === 0) { %>
        <div class="text-center opacity-75 p-4 bg-surface rounded border">No tasks found.</div>
      <% } %>
      <div class="d-flex flex-column gap-3">
        <% tasks.forEach(task => { 
             const typeName = task.TaskType ? task.TaskType.name : '-';
             const clientName = task.Client ? task.Client.name : 'Internal';
             const assigneeName = task.Assignee ? task.Assignee.name : 'Unassigned';
             let badgeClass = 'text-secondary border-secondary';
             if (task.status === 'Completed') badgeClass = 'text-success border-success';
             else if (task.status === 'Overdue') badgeClass = 'text-danger border-danger';
             else if (task.status === 'In Progress') badgeClass = 'text-primary border-primary';
        %>
          <div class="tasks-task-row p-3 border rounded shadow-sm bg-surface" onclick="openTaskModal('<%= task.id %>')">
            <div class="d-flex justify-content-between align-items-start mb-1">
              <h6 class="fw-bold mb-0"><%= typeName %></h6>
              <span class="badge bg-transparent border <%= badgeClass %>" style="font-size: 0.65rem;"><%= task.status %></span>
            </div>
            <div class="opacity-75 small mb-2"><%= clientName %> &middot; <%= assigneeName %></div>
            <div class="d-flex justify-content-between align-items-center mt-2 border-top pt-2">
              <span class="opacity-75 small" style="font-size: 0.75rem;"><i class="bi bi-calendar-event me-1"></i><%= formatAppDate(task.due_date) %></span>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>

<script>
  const allTasks = <%- JSON.stringify(tasks) %>;
  let editTaskModalObj = null;

  function openTaskModal(taskId) {
    if (!editTaskModalObj) {
      editTaskModalObj = new bootstrap.Modal(document.getElementById('editTaskModal'));
    }
    const task = allTasks.find(t => t.id === taskId);
    if (!task) return;

    document.getElementById('edit_task_id').value = task.id;
    document.getElementById('edit_status_input').value = task.status;
    document.getElementById('edit_client_id_input').value = task.client_id || '';
    document.getElementById('edit_task_type_id_input').value = task.task_type_id || '';
    document.getElementById('edit_assigned_user_id_input').value = task.assigned_user_id || '';
    document.getElementById('edit_due_date_input').value = task.due_date || '';
    document.getElementById('edit_tags_input').value = (task.tags || []).join(', ');

    editTaskModalObj.show();
  }

  async function submitEditTask(e) {
    e.preventDefault();
    const taskId = document.getElementById('edit_task_id').value;
    const errorDiv = document.getElementById('editTaskError');
    errorDiv.style.display = 'none';

    const payload = {
      status: document.getElementById('edit_status_input').value,
      client_id: document.getElementById('edit_client_id_input').value,
      task_type_id: document.getElementById('edit_task_type_id_input').value,
      assigned_user_id: document.getElementById('edit_assigned_user_id_input').value,
      due_date: document.getElementById('edit_due_date_input').value,
      tags: document.getElementById('edit_tags_input').value
    };

    try {
      const response = await fetch('/tasks/' + taskId, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await response.json();
      if (response.ok) {
        reloadWithSuccess('Action completed successfully!');
      } else {
        errorDiv.innerText = data.error || 'Failed to update task.';
        errorDiv.style.display = 'block';
      }
    } catch(err) {
      console.error(err);
      errorDiv.innerText = 'Server error. Please try again.';
      errorDiv.style.display = 'block';
    }
  }

  function updateBulkDeleteAction() {
    const checked = document.querySelectorAll('.row-checkbox:checked');
    const bulkBar = document.getElementById('bulkActionBar');
    const countDisplay = document.getElementById('bulkSelectedCount');
    
    if (checked.length > 0) {
      bulkBar.style.display = 'flex';
      countDisplay.textContent = checked.length + ' selected';
    } else {
      bulkBar.style.display = 'none';
    }
  }

  function toggleAllCheckboxes(event) {
    const checkboxes = document.querySelectorAll('.row-checkbox');
    checkboxes.forEach(cb => cb.checked = event.target.checked);
    updateBulkDeleteAction();
  }

  function sortTable(n) {
    var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
    table = document.querySelector(".table");
    switching = true;
    dir = "asc";
    while (switching) {
      switching = false;
      rows = table.rows;
      for (i = 1; i < (rows.length - 1); i++) {
        shouldSwitch = false;
        x = rows[i].getElementsByTagName("TD")[n];
        y = rows[i + 1].getElementsByTagName("TD")[n];
        if (dir == "asc") {
          if (x.innerHTML.toLowerCase() > y.innerHTML.toLowerCase()) {
            shouldSwitch = true;
            break;
          }
        } else if (dir == "desc") {
          if (x.innerHTML.toLowerCase() < y.innerHTML.toLowerCase()) {
            shouldSwitch = true;
            break;
          }
        }
      }
      if (shouldSwitch) {
        rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
        switching = true;
        switchcount ++;
      } else {
        if (switchcount == 0 && dir == "asc") {
          dir = "desc";
          switching = true;
        }
      }
    }
  }

  // Bulk Delete Modal Logic for Tasks (assigned restriction)
  function confirmBulkDeleteTasks() {
    const checked = document.querySelectorAll('.row-checkbox:checked');
    if (checked.length === 0) return;
    
    const idsToTrash = [];
    let assignedCount = 0;
    
    checked.forEach(cb => {
      const isAssigned = cb.getAttribute('data-assigned') === 'true';
      const status = cb.getAttribute('data-status');
      
      if (isAssigned && ['Assigned', 'In Progress', 'Overdue'].includes(status)) {
        assignedCount++;
      } else {
        idsToTrash.push(cb.value);
      }
    });
    
    if (assignedCount > 0 && idsToTrash.length === 0) {
      showToast(`Cannot delete ${assignedCount} assigned task(s). Please mark them as completed or modify them instead.`, 'danger');
      return;
    }
    
    if (assignedCount > 0) {
      showToast(`${assignedCount} task(s) are assigned and will be skipped.`, 'danger');
    }

    if (idsToTrash.length > 0) {
      if (confirm(`Move ${idsToTrash.length} task(s) to recycle bin?`)) {
        executeBulkTrash(idsToTrash);
      }
    }
  }

  async function executeBulkTrash(ids) {
    try {
      for (const id of ids) {
        await fetch(`/dashboard/tasks/${id}/trash`, { method: 'POST' });
      }
      reloadWithSuccess('Action completed successfully!');
    } catch(err) {
      console.error(err);
      showToast('Error moving tasks to trash.', 'danger');
    }
  }

  // Reactive Search
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('tasksSearch');
    if (searchInput) {
      searchInput.addEventListener('keyup', (e) => {
        const term = e.target.value.toLowerCase();
        const currentRows = document.querySelectorAll('.tasks-task-row');
        currentRows.forEach(row => {
          const text = row.innerText.toLowerCase();
          if (text.includes(term)) {
            row.classList.remove('d-none');
            row.style.display = '';
          } else {
            row.classList.add('d-none');
            row.style.display = 'none';
          }
        });
      });
    }
  });
</script>
